{
  "appId": "it.giggioz.costruisciituoisuccessi",
  "productName": "Costruisci i tuoi successi",
  "directories": {
    "output": "dist-electron"
  },
  "asarUnpack": [
    "backend/dist/**",
    "backend/package.json",
    "node_modules/**"
  ],
  "files": [
    "electron/**/*",
    "frontend/dist/**/*",
    "backend/dist/**/*",
    "backend/package.json",
    "package.json",
    "node_modules/**/*"
  ],
  "extraResources": [
    {
      "from": "electron/backend.env.template",
      "to": "backend.env.template"
    }
  ],
  "mac": {
    "category": "public.app-category.productivity",
    "target": [
      "dmg"
    ]
  },
  "win": {
    "target": [
      "nsis"
    ]
  },
  "linux": {
    "target": [
      "AppImage"
    ]
  }
}

